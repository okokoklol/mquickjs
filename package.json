{
  "name": "@okokoklol/mquickjs",
  "version": "0.1.0",
  "description": "MicroQuickJS WASM — tiny ES5 sandbox with host object injection",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./compile": {
      "import": "./dist/compile.js",
      "types": "./dist/compile.d.ts"
    },
    "./compile/web": {
      "import": "./dist/compile_web.js",
      "types": "./dist/compile_web.d.ts"
    },
    "./mquickjs.wasm": "./dist/mquickjs.wasm"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "bench": "npm run build && node tests/wasm_bench.mjs",
    "build:wasm": "make -f Makefile.wasm",
    "build:ts": "tsc",
    "build": "npm run build:wasm && npm run build:ts",
    "clean": "make -f Makefile.wasm clean && rm -rf dist",
    "test": "npm run build && node tests/wasm_test.mjs"
  },
  "peerDependencies": {
    "@swc/core": "^1",
    "@swc/wasm-web": "^1"
  },
  "peerDependenciesMeta": {
    "@swc/core": {
      "optional": true
    },
    "@swc/wasm-web": {
      "optional": true
    }
  },
  "devDependencies": {
    "@swc/core": "^1",
    "@swc/wasm-web": "^1.15.18",
    "typescript": "^5"
  },
  "license": "MIT"
}
